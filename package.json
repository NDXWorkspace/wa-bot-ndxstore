{
  "name": "wa-bot-ndxstore",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "WhatsApp bot for NDXStore — top up game & Roblox with AI customer service",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "migrate": "node scripts/migrate-schema.mjs",
    "pm2": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop wa-bot-ndxstore",
    "pm2:restart": "pm2 restart wa-bot-ndxstore",
    "pm2:logs": "pm2 logs wa-bot-ndxstore",
    "pm2:save": "pm2 save",
    "check": "node --check index.js && node --check config.js && node --check client.js",
    "lint": "node -e \"console.log('Syntax checking all .js files...')\"",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "dotenv": "^16.4.5",
    "pg": "^8.22.0",
    "qrcode-terminal": "^0.12.0",
    "whatsapp-web.js": "^1.34.0"
  }
}
