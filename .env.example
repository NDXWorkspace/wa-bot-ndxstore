# Supabase
SUPABASE_URL=https://jlfrtyyjxkmdetdbeakv.supabase.co
SUPABASE_KEY=

# Database password (untuk migration script, biasanya sama dengan SUPABASE_KEY)
DB_PASSWORD=

# Nomor admin WhatsApp (format: +628xxx atau 628xxx)
ADMIN_NUMBER=

# Group ID untuk notifikasi order (dapatkan dengan !groupid)
GROUP_ID=

# API password Vercel NDXStore
API_PASSWORD=

# AI
AI_API_KEY=
AI_MODEL=openai
AI_API_BASE=https://text.pollinations.ai

# Groq API Key (optional, untuk AI fallback)
GROQ_API_KEY=

# Groq vision model (optional). Kosongkan = gambar diproses via Pollinations.
# Isi dengan model multimodal terkini dari console.groq.com/docs/models kalau mau pakai Groq.
GROQ_VISION_MODEL=

# Log level: error, warn, info, debug
LOG_LEVEL=info
