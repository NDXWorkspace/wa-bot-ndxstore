# ============================================
# WA Bot NDXStore — Environment Variables
# Copy to .env and fill in your values:
#   cp .env.example .env
# ============================================

# ── Required ──────────────────────────────────

# Supabase project URL & service_role key
# service_role key bypasses RLS — treat like a password.
SUPABASE_URL=https://jlfrtyyjxkmdetdbeakv.supabase.co
SUPABASE_KEY=

# Nomor admin WhatsApp (format: 628xxx, tanpa +)
# Hanya nomor ini yang bisa menjalankan command admin.
ADMIN_NUMBER=

# ── WhatsApp ──────────────────────────────────

# Group ID untuk notifikasi order otomatis.
# Kirim !groupid di dalam grup target untuk mendapat ID-nya.
GROUP_ID=120363411174055948@g.us

# ── API / Vercel ──────────────────────────────

# Base URL aplikasi NDXStore (API endpoint).
API_BASE=https://ndxstoreid.vercel.app

# Password admin untuk akses API NDXStore (!stats, !orders, dll.)
# Dapat dari admin NDXStore.
API_PASSWORD=

# ── AI ────────────────────────────────────────

# Groq API Key (prefix gsk_...). Opsional tapi sangat disarankan.
# AI utama: lebih cepat & pintar dari Pollinations gratis.
GROQ_API_KEY=

# Groq vision model (opsional).
# Kosongkan = gambar diproses via Pollinations.
# Isi dengan model multimodal: llama-3.2-90b-vision-preview
GROQ_VISION_MODEL=

# API key untuk AI endpoint kustom (jika pakai proxy sendiri)
AI_API_KEY=

# Base URL AI kustom.
# Default: https://text.pollinations.ai (gratis, tanpa key)
AI_API_BASE=https://text.pollinations.ai

# Nama model default di AI_API_BASE.
AI_MODEL=openai

# Database password untuk migration script.
# Biasanya sama dengan SUPABASE_KEY.
DB_PASSWORD=

# ── Runtime ───────────────────────────────────

# Port health-check HTTP server (default: 3000)
PORT=3000

# Log level: error | warn | info | debug
LOG_LEVEL=info

# Log directory (default: ./logs)
LOG_DIR=./logs

# Set false to suppress console.log in PM2 mode
LOG_CONSOLE=true

# Notifikasi order — path file untuk persist notified IDs.
# Default: ./.notified.json
NOTIFIED_PATH=./.notified.json
