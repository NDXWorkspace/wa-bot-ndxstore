# ============================================
# WA Bot NDXStore — Environment Variables
# Copy to .env and fill in your values:
#   cp .env.example .env
# ============================================

# ── Required ──────────────────────────────────

# Supabase project URL & service_role key
# service_role key bypasses RLS — treat like a password.
SUPABASE_URL=https://jlfrtyyjxkmdetdbeakv.supabase.co
SUPABASE_KEY=

# Nomor admin WhatsApp (format: 628xxx, tanpa +)
# Hanya nomor ini yang bisa menjalankan command admin.
ADMIN_NUMBER=

# ── WhatsApp ──────────────────────────────────

# Group ID untuk notifikasi order otomatis.
# Kirim !groupid di dalam grup target untuk mendapat ID-nya.
GROUP_ID=120363411174055948@g.us

# ── API / Vercel ──────────────────────────────

# Base URL aplikasi NDXStore (API endpoint).
API_BASE=https://ndxstoreid.vercel.app

# Password admin untuk akses API NDXStore (!stats, !orders, dll.)
# Dapat dari admin NDXStore.
API_PASSWORD=

# ── AI ────────────────────────────────────────

# Groq API Key (prefix gsk_...). Opsional tapi sangat disarankan.
# AI utama: lebih cepat & pintar dari Pollinations gratis.
GROQ_API_KEY=

# Groq API endpoint URL (default: https://api.groq.com/openai/v1/chat/completions)
GROQ_URL=https://api.groq.com/openai/v1/chat/completions

# Groq vision model (opsional).
# Kosongkan = gambar diproses via Pollinations.
# Isi dengan model multimodal: llama-3.2-90b-vision-preview
GROQ_VISION_MODEL=

# API key untuk AI endpoint kustom (jika pakai proxy sendiri)
# AI_API_KEY=

# Base URL AI kustom.
# Default: https://text.pollinations.ai (gratis, tanpa key)
AI_API_BASE=https://text.pollinations.ai

# Nama model default di AI_API_BASE.
AI_MODEL=openai

# Database password untuk migration script.
# Biasanya sama dengan SUPABASE_KEY.
DB_PASSWORD=

# ── Runtime ───────────────────────────────────

# Port health-check HTTP server (default: 3000)
PORT=3000

# Log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# Log format: text | json
LOG_FORMAT=text

# Colorize console output (default: true)
LOG_COLOR=true

# Show date prefix in console log (default: false)
LOG_DATE=false

# Suppress console output entirely (use with PM2)
LOG_CONSOLE=true

# Log sampling rate for debug/trace levels (default: 10 = 1 in 10 messages)
LOG_SAMPLE_RATE=10

# Alert webhook URL for fatal/error (Discord, Telegram, etc.)
# LOG_ALERT_WEBHOOK=https://discord.com/api/webhooks/...

# Health heartbeat interval in ms (default: 300000 = 5 min)
# Set 0 to disable
LOG_HEARTBEAT_MS=300000

# Log directory (default: ./logs)
LOG_DIR=./logs

# Chrome/Chromium path (kustom). Default: auto-detect.
# PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Notifikasi order — path file untuk persist notified IDs.
# Default: ./.notified.json
NOTIFIED_PATH=./.notified.json

# ── GitHub Secrets ─────────────────────────────
# Untuk deployment via GitHub Actions, set Secrets berikut di repo:
# Settings → Secrets and variables → Actions → New repository secret
#
# Nama Secret              Contoh Value
# ───────────────────────────────────────────────────────
# SUPABASE_URL             https://xxxxx.supabase.co
# SUPABASE_KEY             eyJhbGciOiJIUzI1NiIs...
# ADMIN_NUMBER             6285159898005
# GROUP_ID                 120363411174055948@g.us
# API_BASE                 https://ndxstoreid.vercel.app
# API_PASSWORD             NDXADMIN2026
# GROQ_API_KEY             gsk_xxxxx
# GROQ_URL                 https://api.groq.com/openai/v1/chat/completions
# AI_API_BASE              https://text.pollinations.ai
# AI_MODEL                 openai
# LOG_LEVEL                info
# LOG_ALERT_WEBHOOK        https://discord.com/api/webhooks/...
# RENDER_DEPLOY_HOOK       https://api.render.com/deploy/... (opsional)
# SSH_HOST                 123.456.789.0 (opsional, untuk VPS)
# SSH_USERNAME             root (opsional)
# SSH_KEY                  (private key, opsional)
